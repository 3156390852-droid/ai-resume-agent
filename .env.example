# ============================================
# AI Resume Agent — 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# ============================================

# LLM API 配置（硅基流动 SiliconFlow）
OPENAI_API_KEY=your_api_key_here
OPENAI_API_BASE=https://api.siliconflow.cn/v1
MODEL_NAME=deepseek-ai/DeepSeek-V3
EMBEDDING_MODEL=BAAI/bge-m3

# MySQL 数据库连接
# Docker 部署时使用：mysql+pymysql://root:resume123@mysql:3306/ai_resume
# 本地开发时使用：mysql+pymysql://root:your_password@localhost:3306/ai_resume
MYSQL_URL=mysql+pymysql://root:resume123@mysql:3306/ai_resume

# MySQL Root 密码（Docker Compose 使用）
MYSQL_ROOT_PASSWORD=resume123
